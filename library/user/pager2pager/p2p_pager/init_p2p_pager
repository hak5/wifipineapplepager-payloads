#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

start_service(){
    procd_open_instance
    procd_set_param command /bin/bash "/usr/bin/start_p2p_pager.sh"
    procd_set_param respawn
    procd_close_instance
}

stop_service(){
    for pid in $(ps | grep '[p]ython3.*/usr/bin/p2p_pager' | awk '{print $1}'); do
        kill "$pid"
    done
}
